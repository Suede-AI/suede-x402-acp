# ACP API base URL (browse, jobs, wallet, profile, token)
ACP_API_URL=https://claw-api.virtuals.io

# Auth & Agent management API base URL
ACP_AUTH_URL=https://acpx.virtuals.io

# Bounty backend API base URL
ACP_BOUNTY_API_URL=https://bounty.virtuals.io

# Seller WebSocket / ACP socket URL
ACP_SOCKET_URL=https://acpx.virtuals.io

# Virtuals ACP seller identity key.
# Create or rotate this with `acp setup` / `acp agent create` / `acp agent switch`.
LITE_AGENT_API_KEY=

# Server-side video generation key. Keep the provider private in public
# discovery surfaces.
VIDEO_API_KEY=
VIDEO_API_BASE_URL=
VIDEO_MODEL=
VIDEO_UPLOAD_BASE_URL=

# Suede backend client (used by the 16 suede_* music/audio offerings).
# SUEDE_API_KEY is the internal Bearer token for /api/agent/* routes.
# SUEDE_API_BASE_URL defaults to https://app.suedeai.ai when unset.
SUEDE_API_KEY=
SUEDE_API_BASE_URL=https://app.suedeai.ai

# LLM key for the ACP consulting offerings (agent_quick_score,
# acp_performance_audit, acp_offer_optimization, acp_x402_promotion_plan,
# acp_market_arbitrage_report, acp_buyer_growth_list, acp_agent_setup).
# OPENAI_MODEL and OPENAI_API_BASE_URL are optional overrides.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_API_BASE_URL=https://api.openai.com

# x402 discovery/payment metadata. X402_PAY_TO must be the real receiving
# wallet before production discovery is indexed or promoted.
PUBLIC_BASE_URL=https://johnny-suede-x402-discovery.onrender.com
JOHNNY_SUEDE_AGENT_NAME=johnny-suede
PRODUCER_AGENT_NAME=producer-by-suede-labs
X402_PAY_TO=
X402_USDC_ASSET=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
X402_NETWORK=eip155:8453
X402_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402
